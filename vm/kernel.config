# Minimal Linux kernel config for Tempest VM
# Designed for Apple Virtualization Framework
#
# Key features:
# - virtio-vsock for host-guest communication
# - virtio-fs for shared filesystem access
# - Minimal drivers (no hardware, no networking stack)

# Basic setup
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_NR_CPUS=8
CONFIG_PREEMPT=y
CONFIG_NO_HZ_IDLE=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_POSIX_MQUEUE=y
CONFIG_AUDIT=n

# Kernel compression
CONFIG_KERNEL_GZIP=y

# CPU/Architecture
CONFIG_GENERIC_CPU=y

# Memory
CONFIG_FLATMEM=y
CONFIG_SPARSEMEM=n

# Executable formats
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_BINFMT_MISC=n

# Core kernel features
CONFIG_SYSFS=y
CONFIG_PROC_FS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Namespaces (needed for sandboxing)
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# Control groups (needed for resource limits)
CONFIG_CGROUPS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_SCHED=y
CONFIG_MEMCG=y
CONFIG_CGROUP_PIDS=y

# Seccomp (needed for sandboxing)
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# TTY/Console
CONFIG_TTY=y
CONFIG_VT=n
CONFIG_SERIAL_8250=n
CONFIG_HVC_DRIVER=y

# Virtio (core)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y

# Virtio console (for serial output)
CONFIG_VIRTIO_CONSOLE=y
CONFIG_HVC_XEN=n

# Virtio vsock (host-guest communication)
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS_COMMON=y

# Virtio filesystem (shared directories)
CONFIG_FUSE_FS=y
CONFIG_VIRTIO_FS=y

# Block devices (minimal)
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y
CONFIG_VIRTIO_BLK=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_PROC_SYSCTL=y
CONFIG_TMPFS_POSIX_ACL=y

# Pseudo filesystems
CONFIG_DEVPTS_FS=y
CONFIG_HUGETLBFS=n

# Networking (minimal - vsock is configured above, just need unix sockets)
CONFIG_NET=y
CONFIG_UNIX=y
CONFIG_INET=n
CONFIG_IPV6=n
CONFIG_NETFILTER=n
CONFIG_WIRELESS=n
CONFIG_RFKILL=n

# Disable all hardware drivers
CONFIG_PCI=y
CONFIG_PCIEPORTBUS=n
CONFIG_ACPI=y
CONFIG_ACPI_BUTTON=n
CONFIG_ACPI_FAN=n
CONFIG_ACPI_PROCESSOR=n
CONFIG_ACPI_THERMAL=n

# Disable USB
CONFIG_USB_SUPPORT=n

# Disable input devices
CONFIG_INPUT=n
CONFIG_INPUT_KEYBOARD=n
CONFIG_INPUT_MOUSE=n

# Disable graphics
CONFIG_DRM=n
CONFIG_FB=n
CONFIG_VGA_CONSOLE=n

# Disable sound
CONFIG_SOUND=n

# Disable all other drivers
CONFIG_HWMON=n
CONFIG_THERMAL=n
CONFIG_WATCHDOG=n
CONFIG_RTC_CLASS=n
CONFIG_LEDS_CLASS=n
CONFIG_EDAC=n
CONFIG_DMADEVICES=n
CONFIG_VIRT_DRIVERS=n
CONFIG_STAGING=n

# Security
CONFIG_SECURITY=n
CONFIG_SECURITY_SELINUX=n
CONFIG_SECURITY_APPARMOR=n

# Crypto (minimal for basic operations)
CONFIG_CRYPTO=y
CONFIG_CRYPTO_ALGAPI=y
CONFIG_CRYPTO_HASH=y
CONFIG_CRYPTO_CRC32C=y

# Kernel debugging (disable for production)
CONFIG_DEBUG_KERNEL=n
CONFIG_DEBUG_INFO=n
CONFIG_MAGIC_SYSRQ=n
CONFIG_DEBUG_FS=n

# Printk
CONFIG_PRINTK=y
CONFIG_PRINTK_TIME=y

# Module support (disable - everything built-in)
CONFIG_MODULES=n

# Initramfs
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_RD_GZIP=y
